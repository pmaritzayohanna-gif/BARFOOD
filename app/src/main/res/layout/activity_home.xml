<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F8F5FA">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:id="@+id/tvMarca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="BARFOOD"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2D2A32"/>

    <ImageButton
        android:id="@+id/btnCarritoTop"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_menu_view"
        android:contentDescription="Carrito"/>

    </LinearLayout>



<com.google.android.material.imageview.ShapeableImageView
    android:id="@+id/imgUsuario"
    android:layout_width="90dp"
    android:layout_height="90dp"
    android:src="@drawable/barfood"
    android:scaleType="centerCrop"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/white"
    app:layout_constraintTop_toBottomOf="@id/topBar"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

<TextView
    android:id="@+id/tvTituloHome"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:text="Inicio"
    android:textSize="24sp"
    android:textStyle="bold"
    android:textColor="#2D2A32"
    app:layout_constraintTop_toBottomOf="@id/imgUsuario"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

<TextView
    android:id="@+id/tvBienvenido"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:text="Bienvenido"
    android:textSize="16sp"
    android:textColor="#6B6572"
    app:layout_constraintTop_toBottomOf="@id/tvTituloHome"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

<TextView
    android:id="@+id/tvMensaje"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Selecciona una categoría"
    android:textSize="14sp"
    android:textColor="#6B6572"
    app:layout_constraintTop_toBottomOf="@id/tvBienvenido"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>


<androidx.gridlayout.widget.GridLayout
   android:id="@+id/gridCategorias"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    app:columnCount="2"
    app:useDefaultMargins="true"
    app:layout_constraintTop_toBottomOf="@id/tvMensaje"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

<com.google.android.material.card.MaterialCardView
    android:id="@+id/cardCategoriaAlimento"
    android:layout_width="0dp"
    android:layout_height="140dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    app:layout_columnWeight="1"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

<ImageView
    android:layout_width="55dp"
    android:layout_height="55dp"
    android:src="@drawable/ic_barfcomida"/>

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Alimento"
    android:textStyle="bold"
    android:textSize="16sp"/>

   </LinearLayout>
</com.google.android.material.card.MaterialCardView>


<com.google.android.material.card.MaterialCardView
    android:id="@+id/cardCategoriaHuesos"
    android:layout_width="0dp"
    android:layout_height="140dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    app:layout_columnWeight="1"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">


<ImageView
    android:layout_width="55dp"
    android:layout_height="55dp"
    android:src="@drawable/ic_huesoprensado1"/>

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Huesos"
    android:textStyle="bold"
    android:textSize="16sp"/>

  </LinearLayout>
</com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCategoriaSuplemento"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_columnWeight="1"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

    <ImageView
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:src="@drawable/ic_suplementoperro"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Suplemento"
        android:textStyle="bold"
        android:textSize="16sp"/>
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCategoriaHigiene"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_columnWeight="1"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

    <ImageView
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:src="@drawable/ic_champuhigiene"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Higiene"
        android:textStyle="bold"
        android:textSize="16sp"/>

      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.gridlayout.widget.GridLayout>

    <Button
        android:id="@+id/btnCarrito"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Ver carrito"
        android:textAllCaps="false"
        android:backgroundTint="#FF9800"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/gridCategorias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>




    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Cerrar sesión"
        android:textAllCaps="false"
        android:backgroundTint="#7E57C2"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/btnCarrito"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>




















